{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.2.5|^8.0",
        "arcanedev/log-viewer": "7.1.0",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "binarytorch/larecipe": "^2.5",
        "binarytorch/larecipe-dark-theme": "^0.1.5",
        "brick/phonenumber": "^0.4.0",
        "darryldecode/cart": "^4.2",
        "elgibor-solution/laravel-database-encryption": "^1.1",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "google/recaptcha": "1.2",
        "graham-campbell/markdown": "13.1",
        "guzzlehttp/guzzle": "^6.3.1|^7.0.1",
        "hexadog/laravel-themes-manager": "^1.8",
        "hongyukeji/laravel-hook": "^1.1",
        "laravel/framework": "^7.29",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^2.4",
        "nwidart/laravel-modules": "^8.2",
        "phpseclib/phpseclib": "^3.0",
        "pragmarx/google2fa-laravel": "^2.2",
        "ramsey/uuid": "^4.1",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-backup": "^6.16",
        "spatie/laravel-permission": "^4.0",
        "symfony/property-access": "4.4",
        "symfony/serializer": "4.4",
        "tightenco/ziggy": "^1.4",
        "tucker-eric/eloquentfilter": "^2.4",
        "xendit/xendit-php": "^2.15",
        "yajra/laravel-datatables-oracle": "~9.0",
        "ytake/laravel-smarty": "4.0.0",
        "zanysoft/laravel-zip": "^1.0"
    },
    "require-dev": {
        "facade/ignition": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/dusk": "^6.19",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^4.3",
        "phpunit/phpunit": "^8.5.8|^9.3.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "hexadog/laravel-theme-installer": false
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
